PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/krishilink

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_TIMEOUT_MS=30000
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Live Tracking (optional)
# TRACKING_DEFAULT_SPEED_KMH=45

# Notifications (optional — no external provider)
# NOTIFICATION_SMS_SENDER_ID=KRISHILK
# NOTIFICATION_EMAIL_FROM=noreply@krishilink.in
# NOTIFICATION_EMAIL_FROM_NAME=KrishiLink
# NOTIFICATION_PUSH_APP_ID=krishilink-app

# Return Trip Marketplace (optional)
# RETURN_TRIP_SEARCH_RADIUS_KM=50
# RETURN_TRIP_MAX_SUGGESTIONS=10

# Shared Truck Matching (optional)
# DEFAULT_TRUCK_CAPACITY_KG=5000

# JWT Auth (Admin Backend)
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
